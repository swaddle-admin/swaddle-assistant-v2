{
  "info": {
    "name": "Swaddle Assistant API",
    "description": "Collection for testing Swaddle Assistant endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Chat",
      "item": [
        {
          "name": "General Chat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Hello, how are you?\",\n  \"user_id\": 1,\n  \"timezone\": \"Africa/Lagos\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/chat",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["chat"]
            }
          }
        },
