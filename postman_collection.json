    {
      "name": "Chat History",
      "item": [
        {
          "name": "Add Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"role\": \"user\",\n  \"content\": \"Hello!\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/chat-history",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["chat-history"]
            }
          }
        },
        {
          "name": "Get All Messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/chat-history/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["chat-history", "1"]
            }
          }
        },
        {
          "name": "Get Recent Messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/chat-history/recent/1?limit=6",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["chat-history", "recent", "1"],
              "query": [
                {
                  "key": "limit",
                  "value": "6"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/chat-history/1/message/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["chat-history", "1", "message", "1"]
            }
          }
        },
        {
          "name": "Delete All Messages",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/chat-history/1/messages",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["chat-history", "1", "messages"]
            }
          }
        }
      ]
    },
